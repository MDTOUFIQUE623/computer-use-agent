GEMINI_API_KEY = your_gemini_api_key_here
SPOTIFY_CLIENT_ID=your_id #if you want to add spotify directly
SPOTIFY_CLIENT_SECRET=your_secret
NOTION_API_KEY=your_notion_api_key 


# --- Phase 3: CDP Browser Attach (optional) ---
# BROWSER_MODE=attach                          # default: launch
# CDP_URL=http://localhost:9222
# CDP_TAB_POLICY=new                           # new | reuse

# Must exactly match a Redirect URI registered on your Spotify Developer
# Dashboard app page, or authorization will fail.
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Space-separated. Only override if you need scopes beyond playback
# control + reading your own playlist library.
# SPOTIFY_SCOPES=user-read-playback-state user-modify-playback-state user-read-currently-playing playlist-read-private playlist-read-collaborative
#
# Run once before first use: python scripts/spotify_login.py
# Requires a Spotify Premium account — playback control (not just
# reading state) is a Premium-only API capability.
